{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mosquitto_pub -h 127.0.0.1 -p 1883 -q 0 -t clauduino/led/stop -m '' || true"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mosquitto_pub -h 127.0.0.1 -p 1883 -q 0 -t clauduino/led/subagent_stop -m '' || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mosquitto_pub -h 127.0.0.1 -p 1883 -q 0 -t clauduino/led/notification -m '' || true"
          }
        ]
      }
    ]
  }
}
